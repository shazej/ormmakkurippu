datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  MANAGER
}

enum UseCase {
  myself
  team
}

model User {
  id                  String    @id @default(uuid())
  google_uid          String?   @unique // Link to Google Auth
  password_hash       String?   // Optional for social-only users
  password_updated_at DateTime?
  primary_email_id    String?   @unique // Ensure unique email
  marketing_mobile    String?
  use_case            UseCase?
  preferences         Json?     @default("{}")
  role                Role      @default(USER)
  created_at          DateTime  @default(now())
  onboarding_step     Int       @default(1)
  is_onboarded        Boolean   @default(false)
  updated_at          DateTime  @updatedAt
  display_name        String?
  avatar_url          String?
  default_workspace_id String?

  emails              UserEmail[]
  mfa_methods         MfaMethod[]
  webauthn_creds      WebAuthnCredential[]
  allowed_ips         AllowedIp[]
  geofence            Geofence?
  app_passwords       AppPassword[]
  sessions            Session[]
  oauth_consents      OAuthConsent[]
  notification_settings NotificationSettings?
  notifications         Notification[]
  notification_preference NotificationPreference?
  audit_logs          AuditLog[]
  tasks               Task[]
  assigned_tasks      Task[]    @relation("AssignedTasks")
  labels              Label[]
  linked_accounts     LinkedAccount[]
  owned_groups        Group[]
  group_memberships   GroupMember[]
  contacts            Contact[]
  call_logs           CallLog[]
  call_transcripts    CallTranscript[]
  call_analyses       CallAnalysis[]
  owned_workspaces    Workspace[]
  workspace_memberships WorkspaceMember[]
  sent_invites        WorkspaceInvite[]
  created_share_links TaskShareLink[]
  created_projects    Project[]

  @@map("users")
}

model UserEmail {
  id                      String    @id @default(uuid())
  user_id                 String
  email                   String    @unique
  is_primary              Boolean   @default(false)
  is_verified             Boolean   @default(false)
  verification_token_hash String?
  verification_expires_at DateTime?
  created_at              DateTime  @default(now())

  user                    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_emails")
}

enum MfaType {
  totp
  webauthn
  email_otp
}

enum MfaStatus {
  enabled
  disabled
}

model MfaMethod {
  id               String    @id @default(uuid())
  user_id          String
  type             MfaType
  status           MfaStatus
  secret_encrypted String?
  name             String?
  created_at       DateTime  @default(now())
  last_used_at     DateTime?

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("mfa_methods")
}

model WebAuthnCredential {
  id            String    @id @default(uuid())
  user_id       String
  credential_id String    @unique
  public_key    String
  counter       Int       @default(0)
  device_name   String?
  created_at    DateTime  @default(now())
  last_used_at  DateTime?

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("webauthn_credentials")
}

model AllowedIp {
  id         String   @id @default(uuid())
  user_id    String
  cidr       String
  label      String?
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("allowed_ips")
}

model Geofence {
  user_id           String   @id // 1:1 relation
  enabled           Boolean  @default(false)
  allowed_countries String[] // ISO codes
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("geofences")
}

model AppPassword {
  id            String    @id @default(uuid())
  user_id       String
  name          String
  password_hash String
  last_used_at  DateTime?
  created_at    DateTime  @default(now())
  revoked_at    DateTime?

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("app_passwords")
}

model Session {
  id                 String    @id @default(uuid())
  user_id            String
  refresh_token_hash String?
  user_agent         String?
  ip                 String?
  country            String?
  city               String?
  device_label       String?
  created_at         DateTime  @default(now())
  last_seen_at       DateTime?
  revoked_at         DateTime?

  user               User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("sessions")
}

model OAuthConsent {
  id          String    @id @default(uuid())
  user_id     String
  client_id   String
  client_name String
  scopes      String[]
  created_at  DateTime  @default(now())
  last_used_at DateTime?
  revoked_at  DateTime?

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("oauth_consents")
}

model NotificationSettings {
  user_id                  String   @id
  new_signin_alert         Boolean  @default(true)
  third_party_access_alert Boolean  @default(true)
  newsletter_subscription  Boolean  @default(false)
  updated_at               DateTime @updatedAt

  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

// --- Notification System ---

enum NotificationType {
  TASK_DUE_REMINDER
  TASK_ASSIGNED
  SHARED_TASK_UPDATE
  SUBSCRIPTION_ALERT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

model Notification {
  id          String           @id @default(uuid())
  user_id     String
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  message     String
  link_url    String?          // Frontend route to navigate to
  entity_type String?          // e.g. "task", "subscription"
  entity_id   String?          // ID of the related entity
  data        Json?            // Extra metadata
  is_read     Boolean          @default(false)
  read_at     DateTime?
  created_at  DateTime         @default(now())

  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)])
  @@index([user_id, is_read])
  @@map("notifications")
}

model NotificationPreference {
  id                          String   @id @default(uuid())
  user_id                     String   @unique
  in_app_enabled              Boolean  @default(true)
  email_enabled               Boolean  @default(false)
  task_due_enabled            Boolean  @default(true)
  task_assigned_enabled       Boolean  @default(true)
  shared_task_updates_enabled Boolean  @default(true)
  subscription_alerts_enabled Boolean  @default(true)
  push_enabled                Boolean  @default(false) // Future
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  user                        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  entity_type String
  entity_id   String?
  ip          String?
  user_agent  String?
  metadata    Json?
  created_at  DateTime @default(now())

  user        User?    @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("audit_logs")
}

// --- Application Features ---

model Task {
  id          String    @id @default(uuid())
  user_id     String
  title       String
  description String?
  from_name   String?
  from_phone  String?
  category    String    @default("General")
  priority    String    @default("Medium")
  status      String    @default("Pending")
  due_date    DateTime?
  notes       String?
  
  assigned_to_user_id String?
  assigned_to_email   String?   // For pending invites

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assigned_to User?     @relation("AssignedTasks", fields: [assigned_to_user_id], references: [id])
  call_log    CallLog?  @relation(fields: [related_call_log_id], references: [id])
  contact     Contact?  @relation(fields: [related_contact_id], references: [id])
  related_call_log_id String?
  related_contact_id  String?
  caller_phone_e164   String?   // Denormalized for display
  
  // Reminder tracking
  reminder_sent_at    DateTime? // Prevents duplicate due-date reminders

  // Recurrence
  recurrence_rule        String?   // daily, weekly, monthly
  recurrence_anchor_date DateTime?
  next_instance_id       String?   @unique // To ensure idempotency

  // Project Relation
  project_id          String?
  project             Project?  @relation(fields: [project_id], references: [id])

  task_labels TaskLabel[]

  share_links TaskShareLink[]

  @@index([user_id])
  @@index([assigned_to_user_id])
  @@index([project_id])
  @@map("tasks")
}

model Label {
  id            String      @id @default(uuid())
  owner_user_id String
  name          String
  color         String?     // hex code e.g. "#4A90E2"
  created_at    DateTime    @default(now())

  owner       User        @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  task_labels TaskLabel[]

  @@unique([owner_user_id, name])
  @@index([owner_user_id])
  @@map("labels")
}

model TaskLabel {
  task_id  String
  label_id String

  task  Task  @relation(fields: [task_id], references: [id], onDelete: Cascade)
  label Label @relation(fields: [label_id], references: [id], onDelete: Cascade)

  @@id([task_id, label_id])
  @@map("task_labels")
}

model Contact {
  id            String   @id @default(uuid())
  owner_user_id String
  name          String?
  phone_e164    String   // E.164 format +1234567890
  email         String?
  company       String?
  tags          String[] @default([])
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  owner         User     @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  call_logs     CallLog[]
  tasks         Task[]

  @@unique([owner_user_id, phone_e164])
  @@index([owner_user_id])
  @@map("contacts")
}

model CallLog {
  id            String   @id @default(uuid())
  owner_user_id String
  contact_id    String?
  caller_phone_e164 String
  caller_name   String?
  direction     String   // "INCOMING", "OUTGOING"
  call_time     DateTime @default(now())
  duration_sec  Int?
  notes         String?
  source        String   @default("MANUAL") // "MANUAL", "WEBHOOK", "IMPORT"
  created_at    DateTime @default(now())

  owner         User     @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  contact       Contact? @relation(fields: [contact_id], references: [id])
  tasks         Task[]

  transcript    CallTranscript?
  analysis      CallAnalysis?

  @@index([owner_user_id])
  @@index([caller_phone_e164])
  @@map("call_logs")
}

enum TranscriptStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CallTranscript {
  id                 String           @id @default(uuid())
  call_log_id        String           @unique
  owner_user_id      String
  status             TranscriptStatus @default(PENDING)
  transcript_text    String?
  error_message      String?
  confidence         Float?
  provider           String?
  language           String?
  audio_duration_sec Int?
  completed_at       DateTime?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  call_log  CallLog       @relation(fields: [call_log_id], references: [id], onDelete: Cascade)
  owner     User          @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  analysis  CallAnalysis?

  @@index([owner_user_id])
  @@map("call_transcripts")
}

model CallAnalysis {
  id                   String         @id @default(uuid())
  call_log_id          String         @unique
  transcript_id        String         @unique
  owner_user_id        String
  status               AnalysisStatus @default(PENDING)
  key_points           Json           @default("[]")
  action_items         Json           @default("[]")
  decisions            Json           @default("[]")
  follow_ups           Json           @default("[]")
  sentiment_label      String?
  sentiment_confidence Float?
  sentiment_rationale  String?
  warnings             Json           @default("[]")
  error_message        String?
  provider             String?
  completed_at         DateTime?
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt

  call_log   CallLog        @relation(fields: [call_log_id], references: [id], onDelete: Cascade)
  transcript CallTranscript @relation(fields: [transcript_id], references: [id], onDelete: Cascade)
  owner      User           @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)

  @@index([owner_user_id])
  @@map("call_analyses")
}

model Workspace {
  id            String   @id @default(uuid())
  owner_user_id String
  name          String
  domain        String?  // For auto-join
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  owner         User              @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  projects      Project[]

  @@map("workspaces")
}

model Project {
  id                  String    @id @default(uuid())
  workspace_id        String
  name                String
  color               String?
  created_by_user_id  String
  created_at          DateTime  @default(now())
  archived_at         DateTime?

  workspace           Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  created_by          User      @relation(fields: [created_by_user_id], references: [id])
  tasks               Task[]

  @@index([workspace_id])
  @@map("projects")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum WorkspaceMemberStatus {
  PENDING
  ACTIVE
  DECLINED
}

model WorkspaceMember {
  id           String                @id @default(uuid())
  workspace_id String
  user_id      String?               // Nullable for pending invites by email
  email        String                // Always required for invites
  role         WorkspaceRole         @default(MEMBER)
  status       WorkspaceMemberStatus @default(PENDING)
  joined_at    DateTime?
  created_at   DateTime              @default(now())

  workspace    Workspace             @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         User?                 @relation(fields: [user_id], references: [id])

  @@unique([workspace_id, email])
  @@index([user_id])
  @@map("workspace_members")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model WorkspaceInvite {
  id                 String       @id @default(uuid())
  workspace_id       String
  email              String
  invited_by_user_id String
  status             InviteStatus @default(PENDING)
  created_at         DateTime     @default(now())

  workspace          Workspace    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  invited_by         User         @relation(fields: [invited_by_user_id], references: [id])

  @@index([workspace_id])
  @@index([email])
  @@map("workspace_invites")
}

model LinkedAccount {
  id               String    @id @default(uuid())
  user_id          String
  provider         String
  provider_user_id String
  email            String?
  avatar_url       String?
  access_token     String?
  refresh_token    String?
  created_at       DateTime  @default(now())
  deleted_at       DateTime?

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
  @@index([user_id])
  @@map("linked_accounts")
}

model Group {
  id            String    @id @default(uuid())
  owner_user_id String
  name          String
  description   String?
  created_at    DateTime  @default(now())
  deleted_at    DateTime?

  owner         User          @relation(fields: [owner_user_id], references: [id], onDelete: Cascade)
  members       GroupMember[]

  @@index([owner_user_id])
  @@map("groups")
}

enum GroupRole {
  MEMBER
  ADMIN
}

enum GroupMemberStatus {
  PENDING
  ACCEPTED
}

model GroupMember {
  id        String            @id @default(uuid())
  group_id  String
  user_id   String?           // Nullable if invited by email but not yet registered/linked
  email     String?
  role      GroupRole         @default(MEMBER)
  status    GroupMemberStatus @default(PENDING)
  joined_at DateTime          @default(now())

  group     Group             @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user      User?             @relation(fields: [user_id], references: [id])

  @@index([group_id])
  @@index([user_id])
  @@map("group_members")
}

// --- Task Sharing ---

model TaskShareLink {
  id               String    @id @default(uuid())
  task_id          String
  token            String    @unique  // crypto.randomBytes(32).toString('base64url')
  created_by       String             // user_id of the task owner who created this link

  // Optional expiry. NULL means the link never expires.
  expires_at       DateTime?

  // Granular permissions — stored as JSON so we can extend without migrations.
  // Current schema: { "view": true }
  permissions      Json      @default("{\"view\": true}")

  // Access telemetry
  access_count     Int       @default(0)
  last_accessed_at DateTime?

  // Soft revocation (we keep the row for audit purposes)
  revoked_at       DateTime?

  created_at       DateTime  @default(now())

  task             Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  creator          User      @relation(fields: [created_by], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([token])
  @@map("task_share_links")
}
